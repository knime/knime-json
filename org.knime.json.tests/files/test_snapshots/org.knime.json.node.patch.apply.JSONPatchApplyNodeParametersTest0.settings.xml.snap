<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.knime.org/2008/09/XMLConfig" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.knime.org/2008/09/XMLConfig http://www.knime.org/XMLConfig_2008_09.xsd" key="test">
    <entry key="input.column" type="xstring" value="json"/>
    <entry key="remove.input.column" type="xboolean" value="false"/>
    <entry key="new.column.name" type="xstring" value="patched_json"/>
    <entry key="patch.type" type="xstring" value="merge and patch"/>
    <entry key="keep original when test fails" type="xboolean" value="false"/>
    <entry key="json.patch" type="xstring" value="{&quot;a&quot;:&quot;z&quot;,&quot;c&quot;:{&quot;f&quot;:null}}"/>
</config>
